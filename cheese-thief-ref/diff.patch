+  z-index: 100;
+  transition: transform 1.2s cubic-bezier(0.4, 0, 0.2, 1);
+  pointer-events: none;
+}
+
+@keyframes sleepPulse {
+
+  0%,
+  100% {
+    transform: scale(1);
+    opacity: 0.8;
+  }
+
+  50% {
+    transform: scale(1.05);
+    opacity: 0.4;
+  }
+}
+
+/* Loop Cheese Trail Effect */
+.cheese-trail {
+  position: absolute;
+  left: 50%;
+  top: 50%;
+  width: 0;
+  height: 0;
+  pointer-events: none;
+  z-index: 50;
+}
+
+.trail-cheese {
+  position: absolute;
+  font-size: 1.5rem;
+  animation: trailFly 2.5s infinite ease-in;
+  opacity: 0;
+  margin-left: -12px;
+  margin-top: -12px;
+}
+
+.trail-line {
+  position: absolute;
+  left: 0;
+  top: 0;
+  width: 4px;
+  height: 40px;
+  background: linear-gradient(to bottom, rgba(234, 179, 8, 0.8), transparent);
+  border-radius: 2px;
+  animation: trailLineFly 2.5s infinite ease-in;
+  opacity: 0;
+  transform-origin: top center;
+  margin-left: -2px;
+}
+
+@keyframes trailFly {
+  0% {
+    transform: translate(0, 0) scale(0.5);
+    opacity: 0;
+  }
+
+  10% {
+    opacity: 1;
+    transform: translate(calc(var(--tx) * 0.1), calc(var(--ty) * 0.1)) scale(1);
+  }
+
+  80% {
+    opacity: 1;
+    transform: translate(calc(var(--tx) * 0.8), calc(var(--ty) * 0.8)) scale(1);
+  }
+
+  95% {
+    opacity: 0;
+    transform: translate(var(--tx), var(--ty)) scale(1.2);
+  }
+
+  100% {
+    opacity: 0;
+    transform: translate(var(--tx), var(--ty)) scale(1.2);
+  }
+}
+
+@keyframes trailLineFly {
+  0% {
+    transform: translate(0, 0) rotate(calc(var(--rot) - 90deg));
+    opacity: 0;
+  }
+
+  10% {
+    opacity: 1;
+  }
+
+  80% {
+    opacity: 1;
+  }
+
+  95% {
+    opacity: 0;
+    transform: translate(var(--tx), var(--ty)) rotate(calc(var(--rot) - 90deg));
+  }
+
+  100% {
+    opacity: 0;
+    transform: translate(var(--tx), var(--ty)) rotate(calc(var(--rot) - 90deg));
+  }
+}
+
+@keyframes pulseBorder {
+  0% {
+    box-shadow: 0 0 0 0 rgba(255, 215, 0, 0.4);
+  }
+
+  70% {
+    box-shadow: 0 0 0 10px rgba(255, 215, 0, 0);
+  }
+
+  100% {
+    box-shadow: 0 0 0 0 rgba(255, 215, 0, 0);
+  }
+}
+
+/* О“Г¶Г‡О“Г¶Г‡ Vote Split Header О“Г¶Г‡О“Г¶Г‡ */
+.vote-header-split {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  background: var(--bg2);
+  border: 1px solid var(--border);
+  border-radius: var(--radius);
+  padding: 20px;
+  margin-bottom: 24px;
+}
+
+.vote-status-panel {
+  text-align: center;
+  border-right: 1px solid var(--border);
+  padding-right: 20px;
+  min-width: 200px;
+}
+
+.vote-title-panel {
+  text-align: center;
+}
+
+@media (max-width: 600px) {
+  .vote-header-split {
+    flex-direction: column;
+  }
+
+  .vote-status-panel {
+    border-right: none;
+    border-bottom: 1px solid var(--border);
+    padding-right: 0;
+    padding-bottom: 20px;
+    margin-bottom: 20px;
+    width: 100%;
+  }
+
+  .vote-title-panel {
+    padding-left: 0;
+  }
+}
